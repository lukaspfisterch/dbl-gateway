DBL_GATEWAY_DB=/app/data/trail.sqlite
DBL_GATEWAY_POLICY_MODULE=dbl_policy.allow_all
DBL_GATEWAY_POLICY_OBJECT=policy

# Enable one provider. A single active provider is enough.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_IDS=gpt-4o-mini

