{
  "$schema": "./boundary.schema.json",
  "schema_version": "1",
  "boundary_version": "1",
  "exposure_mode": "demo",
  "admission": {
    "public": {
      "allow_artifact_handle": false,
      "allow_declared_refs": false,
      "max_declared_tools": 0,
      "max_budget": {
        "max_tokens": 4096,
        "max_duration_ms": 30000
      }
    }
  },
  "tool_policy": {
    "families": {
      "exec_like": ["code.*", "shell.*", "exec.*"],
      "web_read": ["http.get", "web.fetch", "web.*"],
      "retrieval": ["search.*", "vector.*", "db.read", "db.*", "sql.*"],
      "llm_assist": ["summarize", "classify", "transform"]
    },
    "matrix": {
      "public": {
        "anonymous": ["web_read"],
        "user": ["web_read", "retrieval"],
        "operator": ["web_read", "retrieval"],
        "internal": ["web_read", "retrieval"]
      },
      "operator": {
        "anonymous": [],
        "user": ["web_read", "retrieval"],
        "operator": ["web_read", "retrieval", "llm_assist"],
        "internal": ["web_read", "retrieval", "llm_assist"]
      },
      "demo": {
        "*": ["*"]
      }
    }
  },
  "surface_rules": {
    "healthz": "public",
    "capabilities": "public",
    "ingress_intent": "public",
    "surfaces": "operator",
    "intent_template": "operator",
    "snapshot": "operator",
    "thread_timeline": "operator",
    "tail": "operator",
    "status": "operator",
    "execution_event": "operator",
    "ui_root": "demo",
    "ui_tail": "demo",
    "ui_capabilities": "demo",
    "ui_snapshot": "demo",
    "ui_policy_structure": "demo",
    "ui_intent": "demo",
    "ui_verify_chain": "demo",
    "ui_replay": "demo",
    "ui_demo_status": "demo",
    "ui_demo_start": "demo"
  }
}
