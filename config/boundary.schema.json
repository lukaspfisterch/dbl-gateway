{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DBL Gateway Boundary Config",
  "type": "object",
  "required": [
    "schema_version",
    "boundary_version",
    "exposure_mode",
    "admission",
    "identity_policy",
    "surface_rules",
    "tool_policy",
    "request_policy",
    "economic_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "boundary_version": {
      "type": "string",
      "minLength": 1
    },
    "exposure_mode": {
      "type": "string",
      "enum": ["public", "operator", "demo"]
    },
    "admission": {
      "type": "object",
      "required": ["public"],
      "properties": {
        "public": {
          "type": "object",
          "required": [
            "allow_artifact_handle",
            "allow_declared_refs",
            "max_declared_tools",
            "max_budget"
          ],
          "properties": {
            "allow_artifact_handle": {
              "type": "boolean"
            },
            "allow_declared_refs": {
              "type": "boolean"
            },
            "max_declared_tools": {
              "type": "integer",
              "minimum": 0
            },
            "max_budget": {
              "type": "object",
              "required": ["max_tokens", "max_duration_ms"],
              "properties": {
                "max_tokens": {
                  "type": "integer",
                  "minimum": 1
                },
                "max_duration_ms": {
                  "type": "integer",
                  "minimum": 1000
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "identity_policy": {
      "type": "object",
      "required": ["mode", "issuers_allowed", "audiences_allowed", "claim_mapping", "tenant_mapping", "role_map"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["dev", "oidc"]
        },
        "issuers_allowed": {
          "$ref": "#/$defs/stringList"
        },
        "audiences_allowed": {
          "$ref": "#/$defs/stringList"
        },
        "claim_mapping": {
          "type": "object",
          "required": ["actor_id", "issuer", "roles"],
          "properties": {
            "actor_id": {
              "$ref": "#/$defs/nonEmptyStringList"
            },
            "issuer": {
              "type": "string",
              "minLength": 1
            },
            "roles": {
              "$ref": "#/$defs/nonEmptyStringList"
            }
          },
          "additionalProperties": false
        },
        "tenant_mapping": {
          "type": "object",
          "required": ["claim", "fallback", "allowlist"],
          "properties": {
            "claim": {
              "type": "string",
              "minLength": 1
            },
            "fallback": {
              "type": "string",
              "minLength": 1
            },
            "allowlist": {
              "$ref": "#/$defs/nonEmptyStringList"
            }
          },
          "additionalProperties": false
        },
        "role_map": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/stringList" }
            ]
          }
        }
      },
      "additionalProperties": false
    },
    "surface_rules": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["public", "operator", "demo"]
      }
    },
    "tool_policy": {
      "type": "object",
      "required": ["families", "matrix"],
      "properties": {
        "families": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/toolFamilyPatternList"
          }
        },
        "matrix": {
          "type": "object",
          "required": ["public", "operator", "demo"],
          "properties": {
            "public": {
              "$ref": "#/$defs/toolFamilyMatrixMode"
            },
            "operator": {
              "$ref": "#/$defs/toolFamilyMatrixMode"
            },
            "demo": {
              "$ref": "#/$defs/toolFamilyMatrixMode"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "request_policy": {
      "type": "object",
      "required": ["classification", "matrix"],
      "properties": {
        "classification": {
          "type": "object",
          "required": ["light_budget"],
          "properties": {
            "light_budget": {
              "$ref": "#/$defs/budgetLimit"
            }
          },
          "additionalProperties": false
        },
        "matrix": {
          "type": "object",
          "required": ["public", "operator", "demo"],
          "properties": {
            "public": {
              "$ref": "#/$defs/requestPolicyMode"
            },
            "operator": {
              "$ref": "#/$defs/requestPolicyMode"
            },
            "demo": {
              "$ref": "#/$defs/requestPolicyMode"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "economic_policy": {
      "type": "object",
      "required": ["matrix"],
      "properties": {
        "matrix": {
          "type": "object",
          "required": ["public", "operator", "demo"],
          "properties": {
            "public": {
              "$ref": "#/$defs/economicPolicyMode"
            },
            "operator": {
              "$ref": "#/$defs/economicPolicyMode"
            },
            "demo": {
              "$ref": "#/$defs/economicPolicyMode"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "budgetLimit": {
      "type": "object",
      "required": ["max_tokens", "max_duration_ms"],
      "properties": {
        "max_tokens": {
          "type": "integer",
          "minimum": 1
        },
        "max_duration_ms": {
          "type": "integer",
          "minimum": 1000
        }
      },
      "additionalProperties": false
    },
    "toolFamilyPatternList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "nonEmptyStringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "toolFamilyList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "toolFamilyMatrixMode": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/toolFamilyList"
      }
    },
    "requestPolicyRule": {
      "type": "object",
      "required": ["decision"],
      "properties": {
        "decision": {
          "type": "string",
          "enum": ["allow", "deny"]
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "max_budget": {
          "$ref": "#/$defs/budgetLimit"
        }
      },
      "additionalProperties": false
    },
    "requestPolicyClassMap": {
      "type": "object",
      "required": ["probe", "intent", "execution_light", "execution_heavy"],
      "properties": {
        "probe": {
          "$ref": "#/$defs/requestPolicyRule"
        },
        "intent": {
          "$ref": "#/$defs/requestPolicyRule"
        },
        "execution_light": {
          "$ref": "#/$defs/requestPolicyRule"
        },
        "execution_heavy": {
          "$ref": "#/$defs/requestPolicyRule"
        }
      },
      "additionalProperties": false
    },
    "requestPolicyMode": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/requestPolicyClassMap"
      }
    },
    "economicPolicyRule": {
      "type": "object",
      "required": ["slot_class", "cost_class", "reservation_required"],
      "properties": {
        "slot_class": {
          "type": "string",
          "enum": ["none", "shared", "reserved"]
        },
        "cost_class": {
          "type": "string",
          "enum": ["low", "bounded", "capped"]
        },
        "reservation_required": {
          "type": "boolean"
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "economicPolicyClassMap": {
      "type": "object",
      "required": ["probe", "intent", "execution_light", "execution_heavy"],
      "properties": {
        "probe": {
          "$ref": "#/$defs/economicPolicyRule"
        },
        "intent": {
          "$ref": "#/$defs/economicPolicyRule"
        },
        "execution_light": {
          "$ref": "#/$defs/economicPolicyRule"
        },
        "execution_heavy": {
          "$ref": "#/$defs/economicPolicyRule"
        }
      },
      "additionalProperties": false
    },
    "economicPolicyMode": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/economicPolicyClassMap"
      }
    }
  },
  "additionalProperties": false
}
